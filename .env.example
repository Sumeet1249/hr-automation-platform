# Optional: LinkedIn session cookie for HR people discovery
# 1. Log into linkedin.com in Chrome
# 2. DevTools → Application → Cookies → linkedin.com → copy "li_at" value
LINKEDIN_LI_AT=

# Set to false to show the browser while scraping
HEADLESS=true

# Production (KloudBean / VPS)
NODE_ENV=production
HOST=0.0.0.0

# Dashboard port (default 3940). Workspace ports — job-scraper 3847, google-search 3848, download 3939, hr-finding 3940, maps 3942
PORT=3940
